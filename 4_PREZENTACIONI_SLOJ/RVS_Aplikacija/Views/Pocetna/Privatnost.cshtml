@{
    ViewData["Title"] = "Politika privatnosti";
}

<div class="container my-5">

    <div class="text-center mb-4">
        <h1 class="fw-bold">@ViewData["Title"]</h1>
        <p class="text-muted">
            e-Poreski sistem Republike Srbije
        </p>
    </div>

    <p class="lead">
        Ova stranica opisuje politiku privatnosti Poreske uprave i način na koji se obrađuju lični podaci korisnika u okviru e-Porezi sistema.
    </p>

    <!-- 1 -->
    <div class="card mb-4 shadow-sm border-0">
        <div class="card-header bg-white fw-bold">
            1. Prikupljanje podataka
        </div>
        <div class="card-body">
            <p>
                Sistem prikuplja samo osnovne podatke neophodne za korišćenje usluga,
                kao što su email adresa, korisničko ime i lozinka prilikom registracije.
            </p>
        </div>
    </div>

    <!-- 2 -->
    <div class="card mb-4 shadow-sm border-0">
        <div class="card-header bg-white fw-bold">
            2. Korišćenje podataka
        </div>
        <div class="card-body">
            <ul class="mb-0">
                <li>Prijava i autentifikacija korisnika</li>
                <li>Obrada poreskih zahteva i usluga</li>
                <li>Poboljšanje sistema i korisničkog iskustva</li>
            </ul>
        </div>
    </div>

    <!-- 3 -->
    <div class="card mb-4 shadow-sm border-0">
        <div class="card-header bg-white fw-bold">
            3. Čuvanje podataka
        </div>
        <div class="card-body">
            <p>
                Podaci se čuvaju na bezbedan način i nisu dostupni trećim licima,
                osim u slučajevima propisanim zakonom Republike Srbije.
            </p>
        </div>
    </div>

    <!-- 4 -->
    <div class="card mb-4 shadow-sm border-0">
        <div class="card-header bg-white fw-bold">
            4. Autori sistema
        </div>
        <div class="card-body">
            <ul class="mb-0">
                <li>Luka Glišić</li>
            </ul>
        </div>
    </div>

    <!-- 5 -->
    <div class="card mb-4 shadow-sm border-0">
        <div class="card-header bg-white fw-bold">
            5. Kontakt
        </div>
        <div class="card-body">
            <p class="mb-1">
                Za pitanja u vezi privatnosti možete nas kontaktirati:
            </p>

            <ul class="mb-0">
                <li>
                    <a href="mailto:lukaglisic.srb@gmail.com">
                        lukaglisic.srb@gmail.com
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <div class="text-center mt-5 text-muted small">
        <p class="mb-1">
            Sistem: e-Poreska uprava Republike Srbije
        </p>
        <p class="mb-1">
            Autor: Luka Glišić
        </p>
        <p class="mb-0">
            Email: lukaglisic.srb@gmail.com
        </p>
    </div>

</div>