@{
    ViewData["Title"] = "Svrha sistema";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">

                    <h1 class="mb-4">Svrha sistema</h1>

                    <div class="row align-items-center">

                        <div class="col-md-5 mb-4 mb-md-0">
                            <img src="/Slike/Dokument.png"
                                 class="img-fluid rounded shadow-sm"
                                 alt="Dokument">
                        </div>

                        <div class="col-md-7">

                            <p class="text-secondary fs-5">
                                Sistem za poresku prijavu nepokretnosti ima za cilj automatizaciju i digitalizaciju procesa
                                podnošenja i obrade poreskih prijava.
                            </p>

                            <p class="text-secondary">
                                Korišćenjem ovog sistema smanjuje se potreba za ručnom obradom podataka, ubrzava se
                                administrativni proces i omogućava preciznije vođenje evidencije o nepokretnostima i poreskim obveznicima.
                            </p>

                            <p class="text-secondary mb-0">
                                Sistem doprinosi većoj efikasnosti poreske uprave i transparentnijem upravljanju
                                podacima u okviru poreskog sistema.
                            </p>

                        </div>

                    </div>

                </div>
            </div>

        </div>
    </div>

</div>