@{
    ViewData["Title"] = "Poreski sistem - Nepokretnosti";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-5">

    <div class="row justify-content-center">
        <div class="col-lg-9">

            <div class="card shadow-sm border-0">
                <div class="card-body p-5">

                    <h1 class="mb-4">Sistem za poresku prijavu nepokretnosti</h1>

                    <p class="text-secondary fs-5">
                        Sistem je namenjen elektronskoj evidenciji i obradi poreskih prijava vezanih za nepokretnosti.
                        Omogućava centralizovano upravljanje podacima o obveznicima i njihovoj imovini,
                        kao i standardizovan proces podnošenja i obrade prijava.
                    </p>

                    <p class="text-secondary">
                        Kroz digitalizovan pristup, sistem obezbeđuje efikasnije evidentiranje nepokretnosti,
                        transparentnost u obradi podataka i smanjenje potrebe za fizičkim dolaskom u poreske službe.
                    </p>

                    <p class="text-secondary mb-0">
                        Svi podaci se obrađuju u skladu sa važećim poreskim propisima i koriste se isključivo u svrhu
                        utvrđivanja i naplate poreza na nepokretnosti.
                    </p>

                </div>
            </div>

        </div>
    </div>

</div>